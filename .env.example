# ADMINDI — plantilla de variables de entorno (NO comitear valores reales).
# Copiar a ".env" y rellenar. Los secretos reales viven solo en el entorno del
# servidor o en el gestor de secretos de la nube.

# ---------- Base de datos / Redis ----------
DB_USERNAME=postgres
DB_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- Cifrado de columnas sensibles ----------
# Base64(32 bytes) — se usa para cifrar phone, contactEmail, CLABE, etc.
# OBLIGATORIO en prod. Si se pierde esta llave, los datos cifrados son irrecuperables.
ENCRYPTION_KEY=

# ---------- App / Bootstrap ----------
APP_URL=http://localhost:3000
ADMIN_EMAIL=superadmin@admindi.com
ADMIN_PASSWORD=change-me

# ---------- Mail SMTP (Fase 1 notificaciones) ----------
# Gmail: usar App Password, NO la contraseña normal (2FA obligatorio).
# https://support.google.com/accounts/answer/185833
MAIL_ENABLED=false
MAIL_PROVIDER=smtp-gmail
MAIL_FROM=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_STARTTLS=true

# ---------- Twilio WhatsApp (Fase 1 notificaciones) ----------
# Deshabilitado por default. Para habilitar:
#   1) Crear proyecto en https://console.twilio.com/
#   2) Aprobar el número WhatsApp y las plantillas de mensaje (HSM) para
#      OWNER_WELCOME, TENANT_WELCOME, TENANT_PAYMENT_REMINDER_*.
#   3) Rellenar TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN + TWILIO_WHATSAPP_FROM.
#   4) Configurar TWILIO_WEBHOOK_PUBLIC_URL con la URL pública exacta (para
#      validar X-Twilio-Signature). Ej: https://api.midominio.com/api/webhooks/twilio/whatsapp
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_DEFAULT_CC=+52
TWILIO_WEBHOOK_PUBLIC_URL=

# ---------- Plantillas WhatsApp aprobadas por Meta (Fase 2 notificaciones) ----------
# Para producción: mensajes iniciados por la plataforma fuera de la ventana de 24h
# REQUIEREN plantilla aprobada (HSM). Cuando cada plantilla aparezca como "Approved"
# en Twilio Console > Messaging > Content Builder, pega su Content SID (HX…) aquí.
# Activar con TWILIO_TEMPLATES_ENABLED=true solo cuando tengas los 10 SIDs.
# Mapping nombre de plantilla → variable (ver docs/WHATSAPP_TEMPLATES.md):
TWILIO_TEMPLATES_ENABLED=false
TWILIO_TEMPLATE_OWNER_WELCOME=            # admindi_owner_welcome_v2
TWILIO_TEMPLATE_TENANT_WELCOME=           # admindi_tenant_welcome_v2
TWILIO_TEMPLATE_OWNER_PROFILE_UPDATED=    # admindi_owner_profile_updated_v3
TWILIO_TEMPLATE_PAYMENT_REMINDER_5D=      # admindi_payment_reminder_5d_v1
TWILIO_TEMPLATE_PAYMENT_REMINDER_3D=      # admindi_payment_reminder_3d_v1
TWILIO_TEMPLATE_PAYMENT_REMINDER_2D=      # admindi_payment_reminder_2d_v1
TWILIO_TEMPLATE_PAYMENT_REMINDER_1D=      # admindi_payment_reminder_1d_v1
TWILIO_TEMPLATE_TRANSFER_CONFIRMED=       # admindi_transfer_confirmed_owner_v2
TWILIO_TEMPLATE_UNPAID_DIGEST=            # admindi_unpaid_digest_v2
TWILIO_TEMPLATE_MONTHLY_REPORT=           # admindi_monthly_report_v2

# ---------- Chatbot WhatsApp (Twilio inbound) ----------
WHATSAPP_BOT_ENABLED=false
WHATSAPP_BOT_OWNER_ENABLED=false
TWILIO_WEBHOOK_PUBLIC_URL=
# Plantillas Bloque C — pagos (aprobadas Meta 24-may-2026)
TWILIO_TEMPLATE_CASH_PAYMENT_PENDING_OWNER=HX8602f66fb94e0b6c920d010210aec94d
TWILIO_TEMPLATE_CASH_PAYMENT_APPROVED=HX44b2bdd7b375c9d546c5a9d40bc25e57
TWILIO_TEMPLATE_CASH_PAYMENT_REJECTED=HXffa5e40f35ec10ed3a6ba0b61ab0838f
TWILIO_TEMPLATE_PAYMENT_AUTO_VALIDATED=HXd771d5490c973edc5c219efb17003099

# ---------- Mercado Pago (Checkout Pro — pago de renta por inquilinos) ----------
# Token de la APLICACIÓN ADMINDI (integrador): webhooks + OAuth. NO es el del dueño.
# El dueño vincula SU cuenta desde el portal (Mi perfil) con su Access Token de prueba
# o OAuth (requiere MP_CLIENT_SECRET).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# App ID (número de aplicación) — panel MP → Detalles de la aplicación
MP_CLIENT_ID=7662041248754134
# Client Secret (NO es el Access Token) — misma pantalla → Credenciales de producción / prueba
# OAuth: MP NO acepta localhost. En local usa ngrok (ver scripts/NGROK_LOCAL.md).
# ./scripts/start-ngrok-tunnel.sh genera .env.ngrok con MP_OAUTH_REDIRECT_URI HTTPS.
MP_OAUTH_REDIRECT_URI=
MP_PUBLIC_BASE_URL=
# Solo tu máquina — https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Solo emergencias dev; dueños usan «Continuar con Mercado Pago»
MP_ALLOW_MANUAL_LINK=false
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=

# ---------- Recordatorios de pago ----------
# Cron del scheduler PaymentReminderScheduler (spring cron). Default: 08:00 CDMX.
ADMINDI_REMINDERS_CRON=0 0 8 * * *

# ---------- Notificaciones agregadas al dueño (Bloque B) ----------
# Digest diario de inquilinos con pago vencido (UnpaidTenantsDigestScheduler).
# Default: 09:00 CDMX. Solo se envía si el dueño tiene al menos 1 factura vencida.
ADMINDI_DIGEST_UNPAID_CRON=0 0 9 * * *

# Reporte mensual del portafolio por dueño (MonthlyReportScheduler).
# Default: día 1 de cada mes a las 08:00 CDMX. Resumen del mes que acaba de terminar.
ADMINDI_REPORTS_MONTHLY_CRON=0 0 8 1 * *

# ---------- QA / local seeding (usuarios de prueba — OFF por defecto) ----------
# No activar en desarrollo normal. Solo para smoke tests automatizados:
#   ADMINDI_QA_SEED_ENABLED=true
ADMINDI_QA_SEED_ENABLED=false
ADMINDI_QA_SEED_STRICT_USER_IDS=false

# ============================================================================
# V55/V56 — Chatbot WhatsApp + IA contable + Banxico adaptativo
# ============================================================================

# ---------- Anthropic Claude (OCR + contabilidad + narrativa + adaptación Banxico) ----------
# ANTHROPIC_API_KEY es un secreto. NO commitear, NO pegar en chats, NO poner en logs.
# Obtén una key en https://console.anthropic.com/settings/keys
# Configura un "Spend limit" en la consola de Anthropic antes de habilitar.
#
# Si ANTHROPIC_ENABLED=false o la key está vacía, el sistema degrada limpio:
#   - El chatbot responde "OCR no disponible" y sigue funcionando para consultas.
#   - La categorización IA de pagos no ocurre (campos quedan null; editable manual).
#   - El reporte mensual omite la narrativa IA (fallback al body estándar).
#   - Banxico CEP cae al scraper sin fallback adaptativo.
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_VISION_MODEL=claude-sonnet-4-5
ANTHROPIC_TIMEOUT_MS=30000
ANTHROPIC_MAX_TOKENS=2048
# Presupuesto duro en USD por usuario por día. Al excederlo, el backend
# responde 'budget_exceeded' y el flujo cae a manual. En prod recomendamos 1.00.
ANTHROPIC_DAILY_BUDGET=1.00
# Precios por millón de tokens — actualizar si Anthropic cambia pricing.
ANTHROPIC_INPUT_COST_MTOK=3.00
ANTHROPIC_OUTPUT_COST_MTOK=15.00

# ---------- Banxico CEP (validación SPEI real) ----------
# En producción: habilitado. Si no hay conexión a internet, el adapter cae al
# modo permisivo (pass-through) para no bloquear pagos durante incidentes.
BANXICO_CEP_ENABLED=true
BANXICO_CEP_URL=https://www.banxico.org.mx/cep/
BANXICO_CEP_TIMEOUT=15000
# User-Agent identificable — NUNCA poner nombres falsos; respetar ToS.
BANXICO_CEP_UA=ADMINDI/1.0 (contact@admindi.mx; CEP validator)
BANXICO_CEP_INTERVAL=1000
# Auto-adaptación con Claude cuando Banxico cambia su HTML.
# Requiere ANTHROPIC_ENABLED=true para operar.
BANXICO_ADAPTIVE_AI=true

# ---------- Chatbot WhatsApp (Fase 3) ----------
# Para habilitar el chatbot necesitas:
#   1. TWILIO_ENABLED=true con credenciales válidas
#   2. ANTHROPIC_ENABLED=true con key válida (para OCR)
#   3. WHATSAPP_BOT_ENABLED=true
# Si falta alguno, el webhook rechaza con 503 o el bot responde degradado.
WHATSAPP_BOT_ENABLED=false
