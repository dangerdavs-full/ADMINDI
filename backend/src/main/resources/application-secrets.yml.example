# ═══════════════════════════════════════════════════════════════════════════
# PLANTILLA de application-secrets.yml — perfil "secrets".
#
# Cómo usarla:
#   1. Copia este archivo como application-secrets.yml (misma carpeta):
#        cp application-secrets.yml.example application-secrets.yml
#   2. Rellena los valores reales. El archivo real está en .gitignore y
#      NUNCA debe subirse al repositorio.
#   3. Arranca el backend con los perfiles: SPRING_PROFILES_ACTIVE=local,secrets
#
# Solo los 3 primeros valores son OBLIGATORIOS para arrancar en local.
# Las integraciones (Twilio, Mercado Pago, Anthropic) son opcionales: si están
# deshabilitadas o sin credenciales, la app degrada limpio sin romperse.
# ═══════════════════════════════════════════════════════════════════════════
spring:
  config:
    activate:
      on-profile: secrets
  datasource:
    # OBLIGATORIO — contraseña del usuario postgres local.
    password: TU_PASSWORD_DE_POSTGRES

app:
  admin:
    # OBLIGATORIO — contraseña inicial del SUPER_ADMIN (primer login).
    password: TU_PASSWORD_DE_SUPERADMIN
  encryption:
    # OBLIGATORIO — Base64 de 32 bytes para cifrar columnas sensibles.
    # Generar con:  openssl rand -base64 32
    key: TU_ENCRYPTION_KEY_BASE64

  # ── Opcional: correo SMTP (notificaciones por email) ──
  mail:
    enabled: false
    provider: smtp-gmail
    from: ""

# ── Opcional: Twilio WhatsApp Business ──
twilio:
  enabled: false
  account-sid: ""
  auth-token: ""
  whatsapp-from: ""

# ── Opcional: Mercado Pago (cobro de rentas) ──
mercadopago:
  access-token: ""
  public-key: ""
  client-id: ""
  client-secret: ""

# ── Opcional: Anthropic Claude (OCR de comprobantes e IA contable) ──
anthropic:
  enabled: false
  api-key: ""
